{
  "tasks": {
    "dev": "deno run --unstable-otel -A --watch --env-file=.env index.ts",
    "production": "deno run --unstable-otel -A --env-file=.env index.ts",
    // --no-check: this package is type-checked by `deno task check` (tasks/check.sh).
    "test": "ENV=test deno test --no-check -A --env-file=.env.test",
    "llm-exercise": "deno run --allow-env --allow-net ./scripts/llm-exercise.ts",
    "provision-ingest-channel": "deno run -A --env-file=.env scripts/provision-ingest-channel.ts"
  },
  "fmt": {
    "exclude": ["./llm_documentation/*"]
  },
  "imports": {
    "@/": "./",
    "@db/sqlite": "jsr:@db/sqlite@0.13.0",
    "ai": "npm:ai@^7.0.30",
    "@cmd-johnson/oauth2-client": "jsr:@cmd-johnson/oauth2-client@^2.0.0",
    "@ai-sdk/anthropic": "npm:@ai-sdk/anthropic@^4.0.15",
    "@ai-sdk/google-vertex": "npm:@ai-sdk/google-vertex@^5.0.21",
    "@ai-sdk/groq": "npm:@ai-sdk/groq@^4.0.11",
    "@ai-sdk/openai": "npm:@ai-sdk/openai@^4.0.15",
    "@ai-sdk/otel": "npm:@ai-sdk/otel@^1.0.30",
    "@std/cli": "jsr:@std/cli@^1.0.12",
    "ajv": "npm:ajv@^8.17.1",
    "gcp-metadata": "npm:gcp-metadata@6.1.0",
    "@opentelemetry/context-async-hooks": "npm:@opentelemetry/context-async-hooks@^2.9.0",
    "@opentelemetry/core": "npm:@opentelemetry/core@^2.9.0",
    "@opentelemetry/sdk-trace-base": "npm:@opentelemetry/sdk-trace-base@^2.9.0",
    "@opentelemetry/semantic-conventions": "npm:@opentelemetry/semantic-conventions@^1.19.0",
    "@arizeai/openinference-semantic-conventions": "npm:@arizeai/openinference-semantic-conventions@^2.5.0",
    "@arizeai/openinference-vercel": "npm:@arizeai/openinference-vercel@^3.1.0",
    "@fal-ai/client": "npm:@fal-ai/client@^1.2.2",
    "@hono/hono": "npm:hono@^4.7.0",
    "@hono/sentry": "npm:@hono/sentry@^1.2.0",
    "@hono/zod-openapi": "npm:@hono/zod-openapi@^0.18.3",
    "@hono/zod-validator": "npm:@hono/zod-validator@^0.4.2",
    "@opentelemetry/api": "npm:@opentelemetry/api@^1.7.0",
    "@opentelemetry/exporter-trace-otlp-proto": "npm:@opentelemetry/exporter-trace-otlp-proto@^0.220.0",
    "@opentelemetry/resources": "npm:@opentelemetry/resources@^2.9.0",
    "@scalar/hono-api-reference": "npm:@scalar/hono-api-reference@^0.11.10",
    "@sentry/deno": "npm:@sentry/deno@^9.3.0",
    "jsonschema": "npm:jsonschema@^1.5.0",
    "hono-pino": "npm:hono-pino@^0.7.0",
    "pino": "npm:pino@^9.6.0",
    "pino-pretty": "npm:pino-pretty@^13.0.0",
    "plaid": "npm:plaid@^36.0.0",
    "stoker": "npm:stoker@^1.4.2",
    "mistreevous": "npm:mistreevous@4.2.0"
  }
}
