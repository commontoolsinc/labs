{
  "description": "Simple two-turn conversation without tools",
  "responses": [
    {
      "type": "sendRequest",
      "response": {
        "role": "assistant",
        "content": "Hi there!",
        "id": "turn-1"
      },
      "assert": {
        "messagesContain": ["Hello"],
        "messageCount": 1
      }
    },
    {
      "type": "sendRequest",
      "response": {
        "role": "assistant",
        "content": "I'm doing well, thanks!",
        "id": "turn-2"
      },
      "assert": {
        "messagesContain": ["Hello", "How are you?"],
        "messageCount": 3
      }
    }
  ]
}
